    };

    // ── Gauge values (live via sliders) ──────────────────────────────────────
    double _g1 = 68, _g2 = 87, _g3 = 23;

    // ── Code snippets ─────────────────────────────────────────────────────────
    string _cLine = @"<JLineChart Data=""@_data"" Height=""180px""
             ShowArea=""true"" ShowDots=""true"" ColorVar=""--j-accent"" />

@code {
    List<JChartPoint> _data = new() {
