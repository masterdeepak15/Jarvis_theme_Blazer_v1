@page "/feedback"
@using JarvisUI.Components
@using JarvisUI.Tokens
@using JarvisUI.Docs.Components
@inject JToastService Toast

<PageTitle>Feedback — JarvisUI</PageTitle>
<DocsPageHeader Title="Feedback" Category="Components"
    Description="JAlert · JProgress · JToast · JModal — every state live." />

<!-- JTOASTPROVIDER + JTOASTSERVICE SETUP -->
<DocSection Title="JToastProvider + JToastService — Setup (Infrastructure)"
    Description="Place JToastProvider once. Already included inside JPageLayout — do not add again if using JPageLayout."
    Code=@(@"<!-- App.razor or MainLayout — place ONCE only if not using JPageLayout -->
<JToastProvider />

<!-- Any component anywhere in the tree -->
@inject JToastService Toast

Toast.Show(""Message"");                                      // info
Toast.Show(""Saved"",    JState.Success);                    // success (3s)
Toast.Show(""Degraded"", JState.Warning, duration: 6000);   // warning (6s)
Toast.Show(""Fault"",    JState.Error,   title: ""CRITICAL""); // error with title")>
    <Preview>
        <div style="display:flex;flex-direction:column;gap:6px;max-width:440px;">
            <JAlert State="JState.Active" Title="NOTE">
                JToastProvider is already inside JPageLayout. Only add it manually if building a custom layout.
            </JAlert>
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:4px;">
                <JBadge Color="JColor.Cyan">JToastProvider</JBadge>
                <JBadge Color="JColor.Cyan">JToastService</JBadge>
                <JBadge Color="JColor.Ghost">&#64;inject</JBadge>
            </div>
        </div>
    </Preview>
</DocSection>


<DocSection Title="JAlert — All 5 States">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:8px;width:100%;">
            <JAlert State="JState.Active"     Title="SYSTEM">All nodes nominal. Last sync 2s ago.</JAlert>
            <JAlert State="JState.Success"    Title="UPLOAD">Transfer complete — 26 files verified.</JAlert>
            <JAlert State="JState.Warning"    Title="BATTERY">Power grid at 18% — switch to backup.</JAlert>
            <JAlert State="JState.Error"      Title="BREACH">CCTV-005 offline. Zone 3 unmonitored.</JAlert>
            <JAlert State="JState.Processing" Title="SYNC">Synchronising node cluster...</JAlert>
        </div>
    </Preview>
</DocSection>

<!-- PROGRESS - BAR + TICKS + LIVE -->
<DocSection Title="JProgress — Bar, Ticks, Indeterminate">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:10px;width:100%;max-width:420px;">
            <div style="font-size:8px;color:var(--j-accent);letter-spacing:.12em;">BAR STYLE</div>
            <JProgress Value="@_pval" ShowPercent="true" />
            <JProgress Value="78" Color="JColor.Green"  ShowPercent="true" />
            <JProgress Value="95" Color="JColor.Amber"  ShowPercent="true" />
            <JProgress Value="22" Color="JColor.Red"    ShowPercent="true" />
            <div style="font-size:8px;color:var(--j-accent);letter-spacing:.12em;margin-top:4px;">TICK STYLE</div>
            <JProgress Value="@_pval" ProgressStyle="JProgress.JProgressStyle.Ticks" />
            <JProgress Value="60" ProgressStyle="JProgress.JProgressStyle.Ticks" Color="JColor.Amber" />
            <div style="font-size:8px;color:var(--j-accent);letter-spacing:.12em;margin-top:4px;">INDETERMINATE</div>
            <JProgress Indeterminate="true" />
            <div style="display:flex;gap:8px;align-items:center;">
                <JButton Shape="JButtonShape.LeftNotch" Size="JSize.Sm" OnClick="ProgDown">−</JButton>
                <span style="font-size:10px;color:var(--j-accent);min-width:32px;text-align:center;">@_pval%</span>
                <JButton Shape="JButtonShape.LeftNotch" Size="JSize.Sm" OnClick="ProgUp">+</JButton>
            </div>
        </div>
    </Preview>
</DocSection>

<!-- TOAST -->
<DocSection Title="JToast — 4 Notification Types">
    <Preview>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
            <JButton Shape="JButtonShape.LeftNotch"                     OnClick="ToastInfo">ℹ INFO</JButton>
            <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Green" OnClick="ToastOk">✓ SUCCESS</JButton>
            <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Amber" OnClick="ToastWarn">⚠ WARNING 6s</JButton>
            <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Red"   OnClick="ToastErr">✕ ERROR</JButton>
        </div>
        <p style="font-size:9px;color:var(--j-text-muted);margin-top:8px;">
            Toasts appear top-right. Duration default 4s. Usage: <code style="color:var(--j-accent)">Toast.Show("msg", JState.Warning)</code>
        </p>
    </Preview>
</DocSection>

<!-- MODAL -->
<DocSection Title="JModal — Warning · Error · Success Dialogs">
    <Preview>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Amber" OnClick="@(()=>_m1=true)">⚠ WARNING</JButton>
            <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Red"   OnClick="@(()=>_m2=true)">✕ ERROR</JButton>
            <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Green" OnClick="@(()=>_m3=true)">✓ SUCCESS</JButton>
            <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Cyan"  OnClick="@(()=>_m4=true)">◈ WITH FORM</JButton>
        </div>
    </Preview>
</DocSection>

<JModal @bind-Visible="_m1" Title="CONFIRM SHUTDOWN" State="JState.Warning">
    <ChildContent>
        <p style="color:var(--j-text-secondary);font-size:11px;line-height:1.6;margin:0 0 10px;">
            Initiating shutdown will take all 26 NH-90 devices offline.
        </p>
        <JAlert State="JState.Warning" Title="CAUTION">Sensor network enters standby. Resume in 30s.</JAlert>
    </ChildContent>
    <FooterContent>
        <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Amber" OnClick="@(()=>_m1=false)">CONFIRM</JButton>
        <JButton Shape="JButtonShape.LeftNotch" Variant="JVariant.Outline" OnClick="@(()=>_m1=false)">CANCEL</JButton>
    </FooterContent>
</JModal>

<JModal @bind-Visible="_m2" Title="SYSTEM FAULT" State="JState.Error">
    <ChildContent>
        <JAlert State="JState.Error" Title="CRITICAL">Primary uplink severed. Zone 4 offline.</JAlert>
        <div style="margin-top:8px;"><JDataRow Key="FAULT CODE" Value="ERR-0x4F2" /><JDataRow Key="SINCE" Value="17:34:02" /></div>
    </ChildContent>
    <FooterContent>
        <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Red" OnClick="@(()=>_m2=false)">ACKNOWLEDGE</JButton>
    </FooterContent>
</JModal>

<JModal @bind-Visible="_m3" Title="SYNC COMPLETE" State="JState.Success">
    <ChildContent>
        <JAlert State="JState.Success" Title="SUCCESS">All 26 devices synced successfully.</JAlert>
        <div style="margin-top:8px;"><JDataRow Key="DEVICES" Value="26/26" BarPercent="100" /><JDataRow Key="DURATION" Value="4.2s" /></div>
    </ChildContent>
    <FooterContent>
        <JButton Shape="JButtonShape.LeftNotch" Color="JColor.Green" OnClick="@(()=>_m3=false)">CLOSE</JButton>
    </FooterContent>
</JModal>

<JModal @bind-Visible="_m4" Title="ADD WAYPOINT" State="JState.Active">
    <ChildContent>
        <div style="display:flex;flex-direction:column;gap:8px;">
            <JInput Label="LOCATION NAME" Placeholder="e.g. Motichur Bridge" @bind-Value="_mInput" />
            <JSelect Label="TYPE" Options="@_mTypeOpts" @bind-Value="_mType" />
            <JToggle Label="ACTIVE" @bind-Value="_mActive" />
        </div>
    </ChildContent>
    <FooterContent>
        <JButton Shape="JButtonShape.LeftNotch" OnClick="@(()=>{ Toast.Show($"Added: {_mInput}", JState.Success); _m4=false; })">ADD</JButton>
        <JButton Shape="JButtonShape.LeftNotch" Variant="JVariant.Outline" OnClick="@(()=>_m4=false)">CANCEL</JButton>
    </FooterContent>
</JModal>

@code {
    bool _m1, _m2, _m3, _m4;
    int _pval = 42;
    void ProgUp()   => _pval = Math.Min(100, _pval + 10);
    void ProgDown() => _pval = Math.Max(0,   _pval - 10);
    void ToastInfo()  => Toast.Show("Uplink established");
    void ToastOk()    => Toast.Show("All 26 devices synced", JState.Success);
    void ToastWarn()  => Toast.Show("Memory at 87%", JState.Warning, duration: 6000);
    void ToastErr()   => Toast.Show("CCTV-005 offline", JState.Error, title: "CRITICAL");

    string? _mInput;
    string? _mType = "cctv";
    bool _mActive = true;
    List<JSelect.JSelectOption> _mTypeOpts = new() {
        new("cctv","CCTV"), new("vms","VMS"), new("ptz","PTZ"), new("toll","TOLL"),
    };
}
