@using Microsoft.AspNetCore.Components.Routing
@namespace JarvisUI.Docs

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(JarvisUI.Docs.Components.DocsLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not Found</PageTitle>
        <LayoutView Layout="@typeof(JarvisUI.Docs.Components.DocsLayout)">
            <p style="color:var(--j-text-muted);font-family:'Courier New',monospace;padding:40px;">
                404 — Page not found.
            </p>
        </LayoutView>
    </NotFound>
</Router>
