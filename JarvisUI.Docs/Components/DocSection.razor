@* ================================================================
   DocSection — Docs App Section Component

   SUPPORTED Code patterns (all work):
     Code="@_codeVar"                       ← @code block variable (recommended)
     Code="@("""<JCard>...</JCard>""")"     ← inline C# raw string literal
================================================================ *@
@namespace JarvisUI.Docs.Components
@using JarvisUI.Components
@using JarvisUI.Tokens

<div style="margin-bottom:32px;">

    @* Section heading *@
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
            <h3 style="font-size:11px;font-weight:600;color:var(--j-accent);
                       letter-spacing:0.14em;text-transform:uppercase;margin:0;">
                @Title
            </h3>
            @if (!string.IsNullOrWhiteSpace(Badge))
            {
                <JBadge Color="JColor.Cyan" Size="JSize.Xs">@Badge</JBadge>
            }
        </div>
    }

    @* Description *@
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <p style="font-size:11px;color:var(--j-text-muted);letter-spacing:0.04em;
                  line-height:1.6;margin:0 0 12px;">
            @Description
        </p>
    }

    @* Preview area *@
    <div style="position:relative;background:var(--j-bg-card);
                overflow:@(NoPad || Overflow ? "visible" : "hidden");
                border:1px solid var(--j-border-dim);
                padding:@(NoPad ? "0" : "24px");
                display:flex;flex-direction:column;flex-wrap:wrap;gap:12px;align-items:@Align;">
        @if (!NoPad) {
            <div class="j-scan-v"></div>
            <div style="position:absolute;top:0;left:0;width:8px;height:8px;
                        border-top:1px solid var(--j-border);border-left:1px solid var(--j-border);
                        pointer-events:none;"></div>
        }
        @Preview
    </div>

    @* Code toggle bar *@
    @if (!string.IsNullOrWhiteSpace(Code))
    {
        <div>
            <button @onclick="ToggleCode"
                    style="width:100%;padding:6px 14px;background:var(--j-bg);
                           border:1px solid var(--j-border-dim);border-top:none;
                           color:var(--j-text-dim);font-size:9px;letter-spacing:0.12em;
                           text-transform:uppercase;cursor:pointer;text-align:left;
                           font-family:'Courier New',monospace;transition:color 0.15s;"
                    onmouseover="this.style.color='var(--j-accent)'"
                    onmouseout="this.style.color='var(--j-text-dim)'">
                @(_showCode ? "▲ hide code" : "▼ show code")
            </button>

            @if (_showCode)
            {
                <div style="position:relative;background:var(--j-bg);
                            border:1px solid var(--j-border-dim);border-top:none;
                            padding:14px 16px;overflow-x:auto;">
                    <pre style="margin:0;font-size:11px;color:var(--j-text-secondary);
                                font-family:'Courier New',monospace;line-height:1.6;
                                white-space:pre-wrap;word-break:break-word;
                                tab-size:2;">@Code</pre>
                </div>
            }
        </div>
    }

</div>

@code {
    [Parameter] public string?         Title       { get; set; }
    [Parameter] public string?         Description { get; set; }
    [Parameter] public string?         Badge       { get; set; }
    /// <summary>
    /// Code snippet to display. Accepts any string including C# raw string literals.
    /// In @code block: string _c = @"<JCard>...</JCard>";
    /// Inline:         Code="@("""<JCard>...</JCard>""")"
    /// </summary>
    [Parameter] public string?         Code        { get; set; }
    [Parameter] public string          Align       { get; set; } = "flex-start";
    [Parameter] public bool            NoPad       { get; set; } = false;
    /// <summary>Set true when the preview contains dropdowns/pickers that must overflow the card.</summary>
    [Parameter] public bool            Overflow    { get; set; } = false;
    [Parameter] public RenderFragment? Preview     { get; set; }

    private bool _showCode = false;
    private void ToggleCode() => _showCode = !_showCode;
}
