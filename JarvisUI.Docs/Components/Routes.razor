@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(DocsLayout)" />
    </Found>
    <NotFound>
        <PageTitle>Not Found</PageTitle>
        <LayoutView Layout="typeof(DocsLayout)">
            <p style="color:#475569;font-family:'Courier New',monospace;padding:40px;">
                404 — Page not found.
            </p>
        </LayoutView>
    </NotFound>
</Router>
