@page "/"
@using JarvisUI.Components
@using JarvisUI.Tokens
@using JarvisUI.Docs.Components

<PageTitle>JarvisUI Docs — Overview</PageTitle>

<DocsPageHeader Title="JarvisUI"
Category="Overview"
Description="Cinematic HUD-style Blazor Server component library. 38 components. Inspired by JARVIS / LINKS Mark II. Every element is alive — scan lines, pulsing glows, animated corners, waveforms." />

@* Stats row *@
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:28px;">
    <JStatCard Title="Components"  Value="38"    Sub="ready to use"    Style="JCardStyle.Notched" />
    <JStatCard Title="Card Styles" Value="9"     Sub="HUD frame types" Style="JCardStyle.SideRail" />
    <JStatCard Title="Btn Shapes"  Value="9"     Sub="angular shapes"  Style="JCardStyle.CornerBracket" />
    <JStatCard Title="CSS Lines"   Value="1044"  Sub="zero JS"         Style="JCardStyle.PartialBorder" />
    <JStatCard Title="Animations"  Value="18"    Sub="keyframes"       Style="JCardStyle.GlowBorder" />
</div>

@* Live demo — main orb *@
<DocSection Title="Live Identity Orb"
Description="The JOrb component — the centerpiece of any JARVIS interface. Click to toggle listening state."
Code="@jorbMarkup">
    <Preview>
        <div style="display:flex;flex-direction:column;align-items:center;gap:16px;">
            <JOrb SystemName="JARVIS" State="@_orbState" Size="160px"
            Listening="@_listening" OnClick="ToggleListen" />
            <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
                <JButton Shape="JButtonShape.LeftNotch" Size="JSize.Sm"
                OnClick="() => _orbState = JState.Active">Active</JButton>
                <JButton Shape="JButtonShape.LeftNotch" Size="JSize.Sm" Color="JColor.Amber"
                OnClick="() => _orbState = JState.Processing">Processing</JButton>
                <JButton Shape="JButtonShape.LeftNotch" Size="JSize.Sm" Color="JColor.Red"
                OnClick="() => _orbState = JState.Error">Error</JButton>
                <JButton Shape="JButtonShape.LeftNotch" Size="JSize.Sm" Color="JColor.Ghost"
                OnClick="() => _orbState = JState.Idle">Idle</JButton>
            </div>
        </div>
    </Preview>
</DocSection>

@* Quick start *@
<DocSection Title="Quick Start"
Code="@_quickStart">
    <Preview>
        <div style="font-size:11px;color:#475569;letter-spacing:0.04em;line-height:1.8;">
            <div style="color:#22d3ee;">1.</div> Reference JarvisUI project<br/>
            <div style="color:#22d3ee;">2.</div> Call <span style="color:#22d3ee;">builder.Services.AddJarvisUI()</span><br/>
            <div style="color:#22d3ee;">3.</div> Add CSS link in App.razor<br/>
            <div style="color:#22d3ee;">4.</div> Add @("@using") JarvisUI.Components to _Imports.razor<br/>
            <div style="color:#22d3ee;">5.</div> Use <span style="color:#22d3ee;">&lt;JPageLayout&gt;</span> as your app shell
        </div>
    </Preview>
</DocSection>

@* Cards preview *@
<DocSection Title="Card Styles — All 9" Description="Every frame style at a glance.">
    <Preview>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;width:100%;">
            <JStatCard Title="Corner Bracket" Value="S1" Style="JCardStyle.CornerBracket" />
            <JStatCard Title="Notched"        Value="S2" Style="JCardStyle.Notched" />
            <JStatCard Title="Side Rail"      Value="S3" Style="JCardStyle.SideRail" />
            <JStatCard Title="Glow Border"    Value="S4" Style="JCardStyle.GlowBorder" />
            <JStatCard Title="Partial"        Value="S5" Style="JCardStyle.PartialBorder" />
            <JStatCard Title="Danger"         Value="S6" Style="JCardStyle.DangerPulse" State="JState.Error" />
        </div>
    </Preview>
</DocSection>

@code {

    private bool   _listening = false;
    private JState _orbState  = JState.Active;

    private void ToggleListen() => _listening = !_listening;

    private string _quickStart = @"
        <ProjectReference Include=""..\JarvisUI\JarvisUI.csproj"" />

        // Program.cs
        builder.Services.AddJarvisUI();

        // App.razor
        <link rel=""stylesheet"" href=""_content/JarvisUI/css/jarvis-ui.css"" />

        // _Imports.razor
        @@using JarvisUI.Components
        @@using JarvisUI.Tokens

        // Any page
        <JPageLayout SystemName=""JARVIS"" Version=""v4"" State=""JState.Active"">
            <SidebarNav>
                <JNavItem Href=""/"" Icon=""⊞"" Label=""Dashboard"" Active=""true"" />
            </SidebarNav>
            <MainContent>@@Body</MainContent>
        </JPageLayout>
        ";
    private string jorbMarkup = @"
        <JOrb SystemName=""JARVIS"" State=""JState.Active"" Size=""160px"" @bind-Listening=""listening"" />
        ";
}
