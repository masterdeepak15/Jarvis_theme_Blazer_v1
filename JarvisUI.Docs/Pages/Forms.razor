@page "/input"
@page "/select"
@page "/toggle"
@page "/slider"
@page "/checkbox"
@page "/radio"
@page "/textarea"
@page "/formfield"
@using JarvisUI.Components
@using JarvisUI.Tokens
@using JarvisUI.Docs.Components

<PageTitle>Forms — JarvisUI Docs</PageTitle>

<DocsPageHeader Title="Form Components"
                Category="Forms"
                Description="All HUD-styled form inputs. Angular shapes, corner brackets, diamond indicators. Fully bound with bind — no JavaScript." />

<DocSection Title="JInput — Text Field"
            Code="@jInputCode">
    <Preview>
        <div style="width:100%;max-width:340px;display:flex;flex-direction:column;gap:10px;">
            <JInput @bind-Value="_inputVal" Label="Voice command" Placeholder="Speak or type..." />
            <JInput @bind-Value="_inputVal" Label="Amber variant" Color="JColor.Amber" Placeholder="Warning input..." />
            <JInput @bind-Value="_inputVal" Label="Disabled" Disabled="true" Placeholder="Cannot edit" />
        </div>
    </Preview>
</DocSection>

<DocSection Title="JSelect — Dropdown"
            Code="@jSelectCode">
    <Preview>
        <div style="width:100%;max-width:300px;display:flex;flex-direction:column;gap:10px;">
            <JSelect @bind-Value="_selectVal" Label="AI Model" Options="@_models" Placeholder="Select model..." />
            <JSelect @bind-Value="_langVal"   Label="Language" Color="JColor.Amber" Options="@_langs" />
        </div>
    </Preview>
</DocSection>

<DocSection Title="JToggle — Switch"
            Code="@jToggleCode">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <JToggle @bind-Value="_toggle1" Label="Voice listening" />
            <JToggle @bind-Value="_toggle2" Label="HUD overlay" Color="JColor.Amber" />
            <JToggle @bind-Value="_toggle3" Label="Auto-start" Color="JColor.Green" />
            <JToggle @bind-Value="_toggle4" Label="Disabled" Disabled="true" />
        </div>
    </Preview>
</DocSection>

<DocSection Title="JSlider — Range"
            Code="@jSliderCode">
    <Preview>
        <div style="width:100%;max-width:320px;display:flex;flex-direction:column;gap:14px;">
            <JSlider @bind-Value="_slider1" Label="Volume" Unit="%" ShowTicks="true" TickCount="8" />
            <JSlider @bind-Value="_slider2" Label="Temperature" Color="JColor.Amber" Min="16" Max="30" Unit="°C" ShowMinMax="true" />
            <JSlider @bind-Value="_slider3" Label="Sensitivity" Color="JColor.Green" />
        </div>
    </Preview>
</DocSection>

<DocSection Title="JCheckbox — Multi-select"
            Code="@jCheckboxCode">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:8px;">
            <JCheckbox @bind-Value="_chk1" Label="Enable voice commands" />
            <JCheckbox @bind-Value="_chk2" Label="Auto-start on boot" Color="JColor.Amber" />
            <JCheckbox @bind-Value="_chk3" Label="Show HUD overlay" Color="JColor.Green" />
            <JCheckbox @bind-Value="_chk4" Label="Disabled option" Disabled="true" />
        </div>
    </Preview>
</DocSection>

<DocSection Title="JRadio — Single select"
            Code="@jRadioCode">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:12px;">
            <JRadio @bind-Value="_radioVal" Label="Select Model" Options="@_radioModels" />
            <JRadio @bind-Value="_radioLang" Label="Language" Options="@_radioLangs" Horizontal="true" Color="JColor.Amber" />
        </div>
    </Preview>
</DocSection>

<DocSection Title="JTextArea — Multi-line"
            Code="@jTextAreaCode">
    <Preview>
        <div style="width:100%;max-width:400px;">
            <JTextArea @bind-Value="_textVal" Label="Mission log" Rows="4" ShowLineCount="true"
                       Placeholder="Enter command or notes..." />
        </div>
    </Preview>
</DocSection>

<DocSection Title="JFormField — Wrapper with validation"
            Code="@jFormFieldCode">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:12px;width:100%;max-width:340px;">
            <JFormField Label="API Key" Required="true" Tag="Secret"
                        Helper="Your Anthropic API key — never logged">
                <JInput @bind-Value="_apiKey" Placeholder="sk-ant-..." />
            </JFormField>
            <JFormField Label="Model" Error="@_modelError">
                <JSelect @bind-Value="_selectVal" Options="@_models" />
            </JFormField>
            <JButton Shape="JButtonShape.LeftNotch" Size="JSize.Sm"
                     OnClick="SimulateError">Simulate Error</JButton>
        </div>
    </Preview>
</DocSection>

@code {
    // -------------------- Form state --------------------
    string? _inputVal;
    string? _selectVal;
    string? _langVal;
    bool    _toggle1 = true, _toggle2, _toggle3, _toggle4;
    double  _slider1 = 65, _slider2 = 22, _slider3 = 50;
    bool   _chk1 = true, _chk2, _chk3, _chk4;
    string? _radioVal  = "llama3:8b";
    string? _radioLang = "en-US";
    string? _textVal;
    string? _apiKey;
    string? _modelError;

    private void SimulateError() =>
        _modelError = _modelError == null ? "Model not available in current config" : null;

    private List<JSelect.JSelectOption> _models = new()
    {
        new("llama3:8b",  "LLaMA 3 8B"),
        new("phi3:mini",  "Phi-3 Mini"),
        new("mistral:7b", "Mistral 7B"),
    };

    private List<JSelect.JSelectOption> _langs = new()
    {
        new("en-US", "English (US)"),
        new("en-GB", "English (UK)"),
        new("fr-FR", "French"),
        new("de-DE", "German"),
    };

    private List<JRadio.JRadioOption> _radioModels = new()
    {
        new("llama3:8b",  "LLaMA 3 8B",  "Fastest · 8B params"),
        new("phi3:mini",  "Phi-3 Mini",  "Lightweight · 3.8B"),
        new("mistral:7b", "Mistral 7B",  "Balanced · 7B params"),
    };

    private List<JRadio.JRadioOption> _radioLangs = new()
    {
        new("en-US", "English"),
        new("fr-FR", "French"),
        new("de-DE", "German"),
    };

    // -------------------- Razor markup strings --------------------
    private string jInputCode = @"<JInput @bind-Value=""val"" Label=""Command"" Placeholder=""Type here..."" />";
    private string jSelectCode = @"<JSelect @bind-Value=""selected"" Label=""Model"" Options=""@opts"" />";
    private string jToggleCode = @"<JToggle @bind-Value=""enabled"" Label=""Listening"" />";
    private string jSliderCode = @"<JSlider @bind-Value=""vol"" Label=""Volume"" Min=""0"" Max=""100"" />";
    private string jCheckboxCode = @"<JCheckbox @bind-Value=""checked"" Label=""Enable voice commands"" />";
    private string jRadioCode = @"<JRadio @bind-Value=""sel"" Options=""@opts"" Label=""Model"" />";
    private string jTextAreaCode = @"<JTextArea @bind-Value=""txt"" Label=""Mission log"" Rows=""4"" ShowLineCount=""true"" />";
    private string jFormFieldCode = @"
<JFormField Label=""API Key"" Required=""true"" Error=""@error"">
    <JInput @bind-Value=""key"" Placeholder=""sk-..."" />
</JFormField>";
}