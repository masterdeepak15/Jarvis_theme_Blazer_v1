@page "/navigation"
@using JarvisUI.Components
@using JarvisUI.Tokens
@using JarvisUI.Docs.Components
@inject NavigationManager Nav

<PageTitle>Navigation + Data — JarvisUI</PageTitle>
<DocsPageHeader Title="Navigation + Data" Category="Components"
    Description="JTabs · JAccordion · JCommandPalette · JTable · JPagination — all live and interactive." />

<!-- TABS -->
<DocSection Title="JTabs — with Badge, Icon, Live Content">
    <Preview>
        <JTabs @bind-ActiveTab="_activeTab">
            <JTab Label="OVERVIEW" Key="ov">
                <div style="padding:12px 0;color:var(--j-text-secondary);font-size:11px;line-height:1.7;">
                    <b style="color:var(--j-accent)">NH-90 ITS Status:</b> All 26 devices reporting.<br/>
                    Last sync: <span style="color:var(--j-ok)">2s ago</span> · Zone coverage: 100% · Active since 06:00
                </div>
            </JTab>
            <JTab Label="SENSORS" Key="sn">
                <div style="padding:12px 0;display:flex;flex-direction:column;gap:4px;">
                    <JDataRow Key="TEMP"      Value="38.2°C"  BarPercent="38" />
                    <JDataRow Key="HUMIDITY"  Value="62%"     BarPercent="62" />
                    <JDataRow Key="WIND"      Value="18 km/h" BarPercent="18" />
                    <JDataRow Key="VISIBILITY" Value="4.2 km" BarPercent="42" />
                </div>
            </JTab>
            <JTab Label="LOGS" Key="lg" Badge="12">
                <div style="padding:12px 0;font-family:monospace;font-size:10px;color:var(--j-text-secondary);line-height:1.8;">
                    [17:04:02] CCTV-018 → ONLINE<br/>
                    [17:03:58] VMS-003 message updated<br/>
                    [17:03:45] PTZ-001 calibration OK<br/>
                    [17:03:12] TOLL-01 lane 3 opened<br/>
                    [17:02:55] CCTV-005 → OFFLINE ⚠
                </div>
            </JTab>
            <JTab Label="CONFIG" Key="cf">
                <div style="padding:12px 0;display:flex;flex-direction:column;gap:8px;max-width:300px;">
                    <JToggle Label="AUTO ALERTS" @bind-Value="_autoAlert" />
                    <JToggle Label="NIGHT MODE"  @bind-Value="_nightMode" Color="JColor.Amber" />
                    <JSlider Label="ALERT THRESHOLD" Min="0" Max="100" @bind-Value="_threshold" />
                </div>
            </JTab>
        </JTabs>
        <div style="margin-top:6px;font-size:9px;color:var(--j-text-muted);">Active tab: <span style="color:var(--j-accent)">@_activeTab</span></div>
    </Preview>
</DocSection>

<!-- ACCORDION -->
<DocSection Title="JAccordion — Collapsible Sections">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:4px;width:100%;">
            <JAccordion Title="DEVICE HEALTH" DefaultOpen="true">
                <div style="display:flex;flex-direction:column;gap:3px;">
                    <JDataRow Key="CCTV ONLINE"  Value="18/20" BarPercent="90" />
                    <JDataRow Key="VMS ONLINE"   Value="2/3"   BarPercent="67" />
                    <JDataRow Key="PTZ ONLINE"   Value="2/2"   BarPercent="100" State="JState.Active" />
                    <JDataRow Key="TOLL ONLINE"  Value="1/1"   BarPercent="100" State="JState.Active" />
                </div>
            </JAccordion>
            <JAccordion Title="WEATHER CONDITIONS">
                <div style="display:flex;flex-direction:column;gap:3px;">
                    <JDataRow Key="TEMP"      Value="38.2°C"  BarPercent="38" />
                    <JDataRow Key="HUMIDITY"  Value="62%"     BarPercent="62" />
                    <JDataRow Key="FOG RISK"  Value="MEDIUM"  />
                </div>
            </JAccordion>
            <JAccordion Title="ALERT CONFIGURATION">
                <div style="display:flex;flex-direction:column;gap:6px;padding:4px 0;">
                    <JToggle Label="EMAIL ALERTS"  @bind-Value="_autoAlert" />
                    <JToggle Label="SMS ALERTS"    @bind-Value="_nightMode" Color="JColor.Amber" />
                </div>
            </JAccordion>
        </div>
    </Preview>
</DocSection>

<!-- COMMAND PALETTE -->
<DocSection Title="JCommandPalette — Ctrl+K Search Overlay">
    <Preview>
        <div>
            <JButton Shape="JButtonShape.LeftNotch" Icon="⌕" OnClick="@(()=>_cmd=true)">OPEN COMMAND PALETTE</JButton>
            <p style="font-size:9px;color:var(--j-text-muted);margin-top:6px;">
                Also: Ctrl+K · ↑↓ navigate · Enter execute · Esc close
            </p>
        </div>
    </Preview>
</DocSection>
<JCommandPalette @bind-Visible="_cmd" Commands="@_commands" OnExecute="CmdExecute" />

<!-- TABLE -->
<DocSection Title="JTable — Data Table with State Column">
    <Preview>
        <JTable Columns="@_cols" Rows="@_rows" StateColumn="status" />
    </Preview>
</DocSection>

<!-- PAGINATION -->
<DocSection Title="JPagination — Page Navigator">
    <Preview>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <JPagination @bind-Page="_page" TotalPages="12" ShowInfo="true" />
            <JPagination @bind-Page="_page2" TotalPages="6" ShowFirstLast="true" />
            <div style="font-size:9px;color:var(--j-text-muted);">Page 1: @_page · Page 2: @_page2</div>
        </div>
    </Preview>
</DocSection>

@code {
    string? _activeTab = "ov";
    bool _autoAlert = true, _nightMode = false;
    double _threshold = 60;
    bool _cmd;
    int _page = 1, _page2 = 1;

    List<JCommandPalette.JCommand> _commands = new() {
        new("Overview",      "/",           "⊞"),
        new("Theme System",  "/theme",      "◉"),
        new("Identity/HUD",  "/identity",   "◎"),
        new("Cards",         "/cards",      "▣"),
        new("Buttons",       "/buttons",    "▷"),
        new("Form Controls", "/forms",      "⌨"),
        new("NH-90 ITS Map", "/map",        "◎"),
    };

    void CmdExecute(JCommandPalette.JCommand c) { _cmd = false; Nav.NavigateTo(c.Key); }

    List<JTable.JTableColumn> _cols = new() {
        new("ID",     "id"),
        new("DEVICE", "device"),
        new("STATUS", "status"),
        new("UPTIME", "uptime"),
        new("PING",   "ping"),
    };
    List<Dictionary<string,object>> _rows = new() {
        new(){["id"]="CCTV-000",["device"]="Haridwar Entry",      ["status"]="Active",     ["uptime"]="99.8%",["ping"]="2ms"},
        new(){["id"]="CCTV-002",["device"]="Shivalik Overpass",   ["status"]="Warning",    ["uptime"]="81.3%",["ping"]="18ms"},
        new(){["id"]="CCTV-005",["device"]="Forest Zone Entry",   ["status"]="Error",      ["uptime"]="0.0%", ["ping"]="—"},
        new(){["id"]="VMS-001", ["device"]="Forest Zone VMS",     ["status"]="Active",     ["uptime"]="100%", ["ping"]="1ms"},
        new(){["id"]="PTZ-001", ["device"]="BHEL Intersection",   ["status"]="Active",     ["uptime"]="99.2%",["ping"]="3ms"},
        new(){["id"]="TOLL-01", ["device"]="Haridwar ECB Plaza",  ["status"]="Success",    ["uptime"]="100%", ["ping"]="1ms"},
        new(){["id"]="CCTV-011",["device"]="NH-72A Junction",     ["status"]="Error",      ["uptime"]="0.0%", ["ping"]="—"},
        new(){["id"]="VMS-002", ["device"]="Doiwala Board",       ["status"]="Warning",    ["uptime"]="82.0%",["ping"]="12ms"},
    };
}
