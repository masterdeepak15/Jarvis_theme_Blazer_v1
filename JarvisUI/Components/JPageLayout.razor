@* ================================================================
   JPageLayout — JARVIS UI Full Application Shell v2
   Fixed 100vh — the window NEVER scrolls.
   Individual panels scroll internally with overflow-auto.

   Layout:
   ┌────────────────────────────────────────┐  ← TOP HUD BAR (fixed)
   ├──────────┬─────────────────────────────┤
   │ SIDEBAR  │  MAIN CONTENT               │  ← flex:1 min-h-0
   │ (fixed)  │  (scrolls internally)       │
   ├──────────┴─────────────────────────────┤
   │  BOTTOM HUD BAR (fixed)                │
   └────────────────────────────────────────┘
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

@if (_booting && ShowBootScreen)
{
    <JBootScreen SystemName="@SystemName" Version="@Version" OnComplete="HandleBootComplete" />
}
else
{
    <div class="j-root">
        <JHudBar Position="JHudBar.JHudBarPosition.Top"
                 SystemLabel="@_topLabel"
                 ShowDots="true"
                 ShowLive="@(State == JState.Active)">
            @TopBarContent
        </JHudBar>

        <div class="j-shell">
            @if (ShowSidebar)
            {
                <JSidebar SystemName="@SystemName" Version="@Version"
                          Width="@SidebarWidth" NavLabel="@NavLabel" State="@State">
                    <NavContent>@SidebarNav</NavContent>
                    <FooterContent>@SidebarFooter</FooterContent>
                </JSidebar>
            }

            <div class="j-content" style="position:relative;">
                <div style="position:absolute;top:6px;left:6px;width:16px;height:16px;
                            border-top:1px solid var(--j-accent);border-left:1px solid var(--j-accent);
                            opacity:.3;pointer-events:none;z-index:10;
                            animation:j-corner-blink 3s ease-in-out infinite;"></div>
                <div style="position:absolute;top:6px;right:6px;width:16px;height:16px;
                            border-top:1px solid var(--j-accent);border-right:1px solid var(--j-accent);
                            opacity:.3;pointer-events:none;z-index:10;
                            animation:j-corner-blink 3s ease-in-out infinite .6s;"></div>

                <div class="j-scroll" style="padding:@ContentPadding;">
                    @MainContent
                </div>
            </div>
        </div>

        <JHudBar Position="JHudBar.JHudBarPosition.Bottom"
                 ShowWaveform="@ShowWaveform"
                 ShowTicks="@ShowTicks"
                 ShowRec="@ShowRec">
            @BottomBarContent
        </JHudBar>

        <JToastProvider />
    </div>
}

@code {
    [Parameter] public string          SystemName     { get; set; } = "JARVIS";
    [Parameter] public string          Version        { get; set; } = "v4.2.1";
    [Parameter] public JState          State          { get; set; } = JState.Active;
    [Parameter] public bool            ShowSidebar    { get; set; } = true;
    [Parameter] public string          SidebarWidth   { get; set; } = "220px";
    [Parameter] public string?         NavLabel       { get; set; } = "Navigation";
    [Parameter] public bool            ShowBootScreen { get; set; } = false;
    [Parameter] public bool            ShowWaveform   { get; set; } = false;
    [Parameter] public bool            ShowTicks      { get; set; } = true;
    [Parameter] public bool            ShowRec        { get; set; } = false;
    [Parameter] public string          ContentPadding { get; set; } = "12px";
    [Parameter] public RenderFragment? SidebarNav     { get; set; }
    [Parameter] public RenderFragment? SidebarFooter  { get; set; }
    [Parameter] public RenderFragment? MainContent    { get; set; }
    [Parameter] public RenderFragment? TopBarContent  { get; set; }
    [Parameter] public RenderFragment? BottomBarContent { get; set; }

    private bool   _booting  = true;
    private string _topLabel => $"{SystemName} · {Version}";

    protected override void OnInitialized()
    {
        if (!ShowBootScreen) _booting = false;
    }

    private void HandleBootComplete() => _booting = false;
}
