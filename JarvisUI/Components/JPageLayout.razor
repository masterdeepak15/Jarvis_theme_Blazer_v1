@* ================================================================
   JPageLayout — JARVIS UI Full Application Shell
   Combines JSidebar + JHudFrame + JHudBar into a complete
   app layout. The outermost wrapper for your JARVIS app.

   USAGE:
   <JPageLayout SystemName="JARVIS" Version="v4.2.1"
                State="JState.Active" ShowBootScreen="true">
       <SidebarNav>
           <JNavItem Href="/" Icon="⊞" Label="Dashboard" Active="true" />
           <JNavItem Href="/skills" Icon="⚡" Label="Skills" Badge="12" />
       </SidebarNav>
       <MainContent>
           @Body
       </MainContent>
   </JPageLayout>
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

@if (_booting && ShowBootScreen)
{
    <JBootScreen SystemName="@SystemName"
                 Version="@Version"
                 OnComplete="HandleBootComplete" />
}
else
{
    <div style="@_rootStyle">

        @* ── Sidebar ── *@
        @if (ShowSidebar)
        {
            <JSidebar SystemName="@SystemName"
                      Version="@Version"
                      Color="@Color"
                      State="@State"
                      Width="@SidebarWidth"
                      NavLabel="@NavLabel">
                <NavContent>
                    @SidebarNav
                </NavContent>
                <FooterContent>
                    @SidebarFooter
                </FooterContent>
            </JSidebar>
        }

        @* ── Main column ── *@
        <div style="flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden;">

            @* Top HUD bar *@
            <JHudBar Position="JHudBar.JHudBarPosition.Top"
                     Color="@Color"
                     SystemLabel="@_topBarLabel"
                     ShowDots="true"
                     ShowLive="@(State == JState.Active)">
                @TopBarContent
            </JHudBar>

            @* Corner frame overlay *@
            <div style="position:relative;flex:1;overflow:auto;">

                @* Full-screen corner brackets *@
                <div style="position:absolute;top:8px;left:8px;width:20px;height:20px;
                            border-top:2px solid @_accentHex;border-left:2px solid @_accentHex;
                            opacity:0.4;pointer-events:none;z-index:10;
                            animation:j-corner-blink 3s ease-in-out infinite;"></div>
                <div style="position:absolute;top:8px;right:8px;width:20px;height:20px;
                            border-top:2px solid @_accentHex;border-right:2px solid @_accentHex;
                            opacity:0.4;pointer-events:none;z-index:10;
                            animation:j-corner-blink 3s ease-in-out infinite 0.6s;"></div>

                @* Main content *@
                <main style="padding:@ContentPadding;min-height:100%;">
                    @MainContent
                </main>

            </div>

            @* Bottom HUD bar *@
            <JHudBar Position="JHudBar.JHudBarPosition.Bottom"
                     Color="@Color"
                     ShowWaveform="@ShowWaveform"
                     ShowTicks="@ShowTicks"
                     ShowRec="@ShowRec">
                @BottomBarContent
            </JHudBar>

        </div>

        @* ── Toast provider ── *@
        <JToastProvider />

    </div>
}

@code {
    [Parameter] public string          SystemName      { get; set; } = "JARVIS";
    [Parameter] public string          Version         { get; set; } = "v4.2.1";
    [Parameter] public JColor          Color           { get; set; } = JColor.Cyan;
    [Parameter] public JState          State           { get; set; } = JState.Active;
    [Parameter] public bool            ShowSidebar     { get; set; } = true;
    [Parameter] public string          SidebarWidth    { get; set; } = "220px";
    [Parameter] public string?         NavLabel        { get; set; } = "Navigation";
    [Parameter] public bool            ShowBootScreen  { get; set; } = false;
    [Parameter] public bool            ShowWaveform    { get; set; } = false;
    [Parameter] public bool            ShowTicks       { get; set; } = true;
    [Parameter] public bool            ShowRec         { get; set; } = false;
    [Parameter] public string          ContentPadding  { get; set; } = "16px";
    [Parameter] public RenderFragment? SidebarNav      { get; set; }
    [Parameter] public RenderFragment? SidebarFooter   { get; set; }
    [Parameter] public RenderFragment? MainContent     { get; set; }
    [Parameter] public RenderFragment? TopBarContent   { get; set; }
    [Parameter] public RenderFragment? BottomBarContent{ get; set; }

    private bool _booting = true;

    protected override void OnInitialized()
    {
        if (!ShowBootScreen) _booting = false;
    }

    private void HandleBootComplete() => _booting = false;

    private string _topBarLabel => $"{SystemName} · {Version}";

    private string _accentHex => Color switch
    {
        JColor.Amber => "#f97316",
        JColor.Red   => "#ef4444",
        JColor.Green => "#22c55e",
        _            => "#00e5ff",
    };

    private string _rootStyle =>
        "display:flex;min-height:100vh;background:#020d18;" +
        "font-family:'Courier New',monospace;overflow:hidden;position:relative;";
}
