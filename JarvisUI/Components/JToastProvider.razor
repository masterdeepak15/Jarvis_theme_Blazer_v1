@* ================================================================
   JToastProvider — Container for JToast notifications.
   Place ONCE in App.razor or MainLayout (already inside JPageLayout).

   SETUP: <JToastProvider />
   USAGE: @inject JToastService Toast  →  Toast.Show("msg")
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components
@implements IDisposable

<div style="position:fixed;bottom:24px;right:24px;z-index:2000;
            display:flex;flex-direction:column-reverse;gap:8px;
            pointer-events:none;width:320px;">
    @foreach (var toast in _service.Toasts)
    {
        <JToast Model="toast" OnDismiss="() => _service.Remove(toast.Id)" />
    }
</div>

@code {
    [Inject] private JToastService _service { get; set; } = default!;

    private bool _disposed = false;

    protected override void OnInitialized()
    {
        _service.OnChange += HandleChange;
    }

    // OnChange fires from background Task.Delay threads — must use InvokeAsync
    private void HandleChange()
    {
        if (_disposed) return;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _disposed = true;
        _service.OnChange -= HandleChange;
    }
}
