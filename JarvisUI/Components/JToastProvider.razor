@* ================================================================
   JToast + JToastProvider — JARVIS UI Toast Notifications
   Corner-stacked HUD notifications with auto-dismiss.

   SETUP (Program.cs):
   builder.Services.AddJarvisUI();
   // JToastService is registered by AddJarvisUI()

   SETUP (App.razor or MainLayout.razor):
   <JToastProvider />

   USAGE (inject in any page/component):
   @inject JToastService Toast
   Toast.Show("Skill loaded", JState.Success);
   Toast.Show("Memory high", JState.Warning, duration: 6000);
   Toast.Show("Engine error", JState.Error, title: "CRITICAL");
================================================================ *@

@* ── JToastProvider ─────────────────────────────────────────── *@
@using JarvisUI.Tokens
@namespace JarvisUI.Components
@implements IDisposable

<div style="position:fixed;bottom:24px;right:24px;z-index:2000;
            display:flex;flex-direction:column-reverse;gap:8px;
            pointer-events:none;width:320px;">
    @foreach (var toast in _service.Toasts)
    {
        <JToast Model="toast" OnDismiss="() => _service.Remove(toast.Id)" />
    }
</div>

@code {
    [Inject] private JToastService _service { get; set; } = default!;

    protected override void OnInitialized()
    {
        _service.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        _service.OnChange -= StateHasChanged;
    }
}
