@* ================================================================
   JAlert — JARVIS UI Alert / Notification
   Angular left-border accent panel with state-driven colors.

   USAGE:
   <JAlert State="JState.Active">JARVIS is online and listening.</JAlert>
   <JAlert State="JState.Warning" Dismissible="true">High memory usage detected.</JAlert>
   <JAlert State="JState.Error" Blink="true">Speech engine failure.</JAlert>
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

@if (_visible)
{
    <div style="@_style" class="@_class">

        @* Left accent rail *@
        <div style="position:absolute;top:0;bottom:0;left:0;width:2px;background:@_accentHex;box-shadow:0 0 8px @_accentHex;@_railAnim"></div>

        @* Icon *@
        <span style="font-style:normal;font-size:13px;flex-shrink:0;@_iconColor">@_icon</span>

        @* Content *@
        <div style="flex:1;font-size:11px;color:@_accentHex;letter-spacing:0.04em;line-height:1.5;">
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <div style="font-weight:600;letter-spacing:0.10em;text-transform:uppercase;margin-bottom:2px;">@Title</div>
            }
            @ChildContent
            @Text
        </div>

        @* Dismiss button *@
        @if (Dismissible)
        {
            <button @onclick="Dismiss"
                    style="background:transparent;border:none;cursor:pointer;
                           color:@_accentHex;opacity:0.6;font-size:14px;
                           padding:0 0 0 8px;flex-shrink:0;font-family:inherit;">
                ✕
            </button>
        }

    </div>
}

@code {
    [Parameter] public JState          State       { get; set; } = JState.Active;
    [Parameter] public string?         Title       { get; set; }
    [Parameter] public string?         Text        { get; set; }
    [Parameter] public bool            Dismissible { get; set; } = false;
    [Parameter] public bool            Blink       { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent{ get; set; }
    [Parameter] public EventCallback   OnDismiss   { get; set; }

    private bool _visible = true;

    private async Task Dismiss()
    {
        _visible = false;
        await OnDismiss.InvokeAsync();
    }

    private string _accentHex => State switch
    {
        JState.Warning => "var(--j-warn)",
        JState.Error   => "var(--j-err)",
        JState.Success => "var(--j-ok)",
        JState.Idle    => "var(--j-accent-35)",
        _              => "var(--j-accent)",
    };

    private string _bgHex => State switch
    {
        JState.Warning => "var(--j-warn-05)",
        JState.Error   => "var(--j-err-05)",
        JState.Success => "var(--j-ok-05)",
        JState.Idle    => "var(--j-accent-05)",
        _              => "var(--j-accent-05)",
    };

    private string _icon => State switch
    {
        JState.Warning => "⚠",
        JState.Error   => "✕",
        JState.Success => "✓",
        _              => "ℹ",
    };

    private string _iconColor => $"color:{@_accentHex};text-shadow:0 0 8px {@_accentHex});";

    private string _railAnim => State switch
    {
        JState.Error   => "animation:j-pulse 0.8s ease-in-out infinite;",
        JState.Warning => "animation:j-pulse 1.5s ease-in-out infinite;",
        _              => "",
    };

    private string _style =>
        $"position:relative;display:flex;align-items:flex-start;gap:10px;" +
        $"padding:10px 14px 10px 16px;" +
        $"background:{_bgHex};" +
        $"clip-path:polygon(0 0,100% 0,calc(100% - 8px) 100%,0 100%);";

    private string _class => Blink ? "j-blink-slow" : "";
}
