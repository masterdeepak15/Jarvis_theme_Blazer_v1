@* ================================================================
   JCheckbox — JARVIS UI Checkbox
   Angular clip-path box with diamond tick mark on check.

   USAGE:
   <JCheckbox @bind-Value="isEnabled" Label="Enable voice commands" />
   <JCheckbox @bind-Value="autoStart" Label="Auto-start on boot" Color="JColor.Amber" />
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

<label style="display:inline-flex;align-items:center;gap:10px;cursor:@(Disabled ? "not-allowed" : "pointer");
              opacity:@(Disabled ? "0.45" : "1");">

    @* Hidden native checkbox *@
    <input type="checkbox" checked="@Value" disabled="@Disabled"
           @onchange="OnChange"
           style="position:absolute;opacity:0;width:0;height:0;" />

    @* Custom angular box *@
    <div style="@_boxStyle" @onclick="() => { if (!Disabled) { } }">

        @* Corner brackets on box *@
        <div style="position:absolute;top:0;left:0;width:5px;height:5px;
                    border-top:1.5px solid var(--j-accent);border-left:1.5px solid var(--j-accent);"></div>
        <div style="position:absolute;bottom:0;right:0;width:5px;height:5px;
                    border-bottom:1.5px solid var(--j-accent);border-right:1.5px solid var(--j-accent);"></div>

        @* Diamond tick *@
        @if (Value)
        {
            <div style="width:8px;height:8px;
                        background:var(--j-accent);
                        clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);
                        box-shadow:0 0 8px var(--j-accent);
                        animation:j-pulse 2s ease-in-out infinite;">
            </div>
        }
        else
        {
            <div style="width:4px;height:4px;border-radius:50%;
                        background:var(--j-accent);opacity:0.2;"></div>
        }

    </div>

    @* Label *@
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <span style="font-size:11px;color:@(Value ? "var(--j-text-primary)" : "var(--j-text-muted)");
                     letter-spacing:0.06em;transition:color 0.2s;
                     font-family:'Courier New',monospace;">
            @Label
        </span>
    }

</label>

@code {
    [Parameter] public bool          Value        { get; set; } = false;
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public string?        Label        { get; set; }
    [Parameter] public JColor         Color        { get; set; } = JColor.Cyan;
    [Parameter] public bool           Disabled     { get; set; } = false;

    private async Task OnChange(ChangeEventArgs e)
    {
        bool v = (bool)(e.Value ?? false);
        Value = v;
        await ValueChanged.InvokeAsync(v);
    }

    private string _accentHex => "var(--j-accent)";

    private string _boxStyle =>
        $"position:relative;width:20px;height:20px;flex-shrink:0;" +
        $"background:{(Value == true ? $"var(--j-accent)18" : "var(--j-bg-card)")};" +
        $"border:1px solid {(Value == true ? _accentHex : "var(--j-accent-18)")};" +
        $"clip-path:polygon(3px 0,100% 0,calc(100% - 3px) 100%,0 100%);" +
        $"display:flex;align-items:center;justify-content:center;" +
        $"box-shadow:{(Value == true ? $"0 0 8px var(--j-accent)44" : "none")};" +
        "transition:all 0.2s;";
}
