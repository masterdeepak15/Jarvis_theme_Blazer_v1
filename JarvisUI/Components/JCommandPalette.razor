@* ================================================================
   JCommandPalette — JARVIS UI Command Palette
   Full-screen voice/keyboard command overlay with live filtering.
   Triggered by keyboard shortcut or button. Pure Blazor, no JS.

   USAGE:
   <JCommandPalette @bind-Visible="showPalette"
                    Commands="@myCommands"
                    OnExecute="HandleCommand"
                    Placeholder="Speak or type a command..." />

   var myCommands = new List<JCommand> {
       new("Open Dashboard",  "dashboard",  "⊞", "Navigation"),
       new("Load Skills",     "skills",     "⚡", "System"),
       new("Shutdown JARVIS", "shutdown",   "⏻", "System", JState.Error),
   };
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

@if (Visible)
{
    @* Backdrop *@
    <div style="position:fixed;inset:0;z-index:3000;
                background:rgba(2,13,24,0.92);
                backdrop-filter:blur(4px);"
         @onclick="Close">
    </div>

    @* Palette panel *@
    <div style="@_panelStyle" @onclick:stopPropagation="true">

        @* Top corner brackets *@
        <div style="@_corner("top:0;left:0;border-top-width:2px;border-left-width:2px;")"></div>
        <div style="@_corner("top:0;right:0;border-top-width:2px;border-right-width:2px;")"></div>

        @* Scan line *@
        <div style="position:absolute;left:0;right:0;height:1px;top:-1px;
                    background:linear-gradient(90deg,transparent,#00e5ff,transparent);
                    box-shadow:0 0 12px #00e5ff;
                    animation:j-scan-v 3s ease-in-out infinite;"></div>

        @* ── Search input ── *@
        <div style="position:relative;padding:12px 16px;
                    border-bottom:1px solid rgba(0,229,255,0.12);">

            @* Mic / search icon *@
            <div style="position:absolute;left:28px;top:50%;transform:translateY(-50%);
                        font-size:14px;color:#22d3ee;
                        filter:drop-shadow(0 0 4px #00e5ff);
                        animation:j-pulse 2s ease-in-out infinite;">
                @(IsListening ? "🎙" : "⌕")
            </div>

            <input @ref="_inputRef"
                   @bind="_query"
                   @bind:event="oninput"
                   @onkeydown="HandleKey"
                   placeholder="@Placeholder"
                   style="width:100%;padding:10px 14px 10px 40px;
                          background:transparent;border:none;outline:none;
                          color:#e0f7ff;font-size:14px;
                          font-family:'Courier New',monospace;
                          letter-spacing:0.06em;box-sizing:border-box;"
                   autocomplete="off" />

            @if (!string.IsNullOrWhiteSpace(_query))
            {
                <button @onclick="() => _query = string.Empty"
                        style="position:absolute;right:28px;top:50%;transform:translateY(-50%);
                               background:transparent;border:none;cursor:pointer;
                               color:#475569;font-size:14px;font-family:inherit;">✕</button>
            }
        </div>

        @* ── Results ── *@
        <div style="max-height:360px;overflow-y:auto;">
            @if (_filtered.Count == 0)
            {
                <div style="padding:24px;text-align:center;
                            font-size:11px;color:#334155;letter-spacing:0.10em;">
                    NO COMMANDS FOUND
                </div>
            }
            else
            {
                string? lastGroup = null;
                for (int i = 0; i < _filtered.Count; i++)
                {
                    var cmd  = _filtered[i];
                    int idx  = i;
                    bool sel = idx == _selectedIdx;

                    @* Group header *@
                    if (cmd.Group != lastGroup)
                    {
                        lastGroup = cmd.Group;
                        <div style="padding:6px 16px 2px;font-size:8px;color:#334155;
                                    letter-spacing:0.14em;text-transform:uppercase;">
                            @cmd.Group
                        </div>
                    }

                    @* Command row *@
                    <div style="@_rowStyle(sel, cmd.State)"
                         @onclick="() => Execute(cmd)"
                         @onmouseenter="() => _selectedIdx = idx">

                        @if (!string.IsNullOrWhiteSpace(cmd.Icon))
                        {
                            <span style="font-style:normal;font-size:14px;
                                         color:@_rowAccent(cmd.State);
                                         filter:drop-shadow(0 0 4px @_rowAccent(cmd.State));
                                         flex-shrink:0;">@cmd.Icon</span>
                        }

                        <div style="flex:1;min-width:0;">
                            <div style="font-size:11px;color:@(sel ? "#e0f7ff" : "#94a3b8");
                                        letter-spacing:0.06em;">@cmd.Label</div>
                            @if (!string.IsNullOrWhiteSpace(cmd.Description))
                            {
                                <div style="font-size:9px;color:#475569;letter-spacing:0.08em;margin-top:1px;">
                                    @cmd.Description
                                </div>
                            }
                        </div>

                        @if (sel)
                        {
                            <span style="font-size:9px;color:#22d3ee;letter-spacing:0.10em;
                                         opacity:0.6;">ENTER</span>
                        }

                    </div>
                }
            }
        </div>

        @* ── Footer hint ── *@
        <div style="padding:6px 16px;border-top:1px solid rgba(0,229,255,0.08);
                    display:flex;gap:16px;font-size:8px;color:#334155;letter-spacing:0.10em;">
            <span>↑↓ NAVIGATE</span>
            <span>↵ EXECUTE</span>
            <span>ESC CLOSE</span>
        </div>

    </div>
}

@code {
    public record JCommand(
        string  Label,
        string  Key,
        string? Icon        = null,
        string? Group       = "General",
        JState  State       = JState.Active,
        string? Description = null
    );

    [Parameter] public bool                 Visible      { get; set; }
    [Parameter] public EventCallback<bool>  VisibleChanged { get; set; }
    [Parameter] public List<JCommand>       Commands     { get; set; } = new();
    [Parameter] public EventCallback<JCommand> OnExecute { get; set; }
    [Parameter] public string               Placeholder  { get; set; } = "Type a command...";
    [Parameter] public bool                 IsListening  { get; set; } = false;

    private string        _query       = string.Empty;
    private int           _selectedIdx = 0;
    private ElementReference _inputRef;

    private List<JCommand> _filtered => string.IsNullOrWhiteSpace(_query)
        ? Commands
        : Commands.Where(c =>
            c.Label.Contains(_query, StringComparison.OrdinalIgnoreCase) ||
            c.Key.Contains(_query,   StringComparison.OrdinalIgnoreCase) ||
            (c.Description?.Contains(_query, StringComparison.OrdinalIgnoreCase) ?? false)
          ).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible) { /* focus input — JS-free focus via autofocus attribute not available,
                          but Blazor ElementReference focus works */ }
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                _selectedIdx = Math.Min(_selectedIdx + 1, _filtered.Count - 1);
                break;
            case "ArrowUp":
                _selectedIdx = Math.Max(_selectedIdx - 1, 0);
                break;
            case "Enter":
                if (_selectedIdx < _filtered.Count)
                    await Execute(_filtered[_selectedIdx]);
                break;
            case "Escape":
                await Close();
                break;
        }
    }

    private async Task Execute(JCommand cmd)
    {
        await OnExecute.InvokeAsync(cmd);
        await Close();
    }

    private async Task Close()
    {
        _query = string.Empty;
        _selectedIdx = 0;
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private string _rowAccent(JState s) => s switch
    {
        JState.Warning => "#f97316",
        JState.Error   => "#ef4444",
        JState.Success => "#22c55e",
        _              => "#22d3ee",
    };

    private string _rowStyle(bool selected, JState state) =>
        "display:flex;align-items:center;gap:10px;padding:10px 16px;cursor:pointer;" +
        $"background:{( selected ? "rgba(0,229,255,0.07)" : "transparent")};" +
        $"border-left:2px solid {(selected ? _rowAccent(state) : "transparent")};" +
        "transition:background 0.1s;";

    private string _panelStyle =>
        "position:fixed;z-index:3001;" +
        "top:20%;left:50%;transform:translateX(-50%);" +
        "width:560px;max-width:calc(100vw - 32px);" +
        "background:#030f1e;overflow:hidden;" +
        "clip-path:polygon(18px 0%,100% 0%,100% calc(100% - 18px),calc(100% - 18px) 100%,0% 100%,0% 18px);" +
        "border:1px solid rgba(0,229,255,0.25);" +
        "box-shadow:0 0 40px rgba(0,229,255,0.15),0 0 80px rgba(0,229,255,0.06);" +
        "font-family:'Courier New',monospace;";

    private string _corner(string pos) =>
        $"position:absolute;{pos}width:14px;height:14px;" +
        "border-color:#00e5ff;border-style:solid;border-width:0;" +
        "filter:drop-shadow(0 0 4px #00e5ff);" +
        "animation:j-corner-blink 3s ease-in-out infinite;";
}
