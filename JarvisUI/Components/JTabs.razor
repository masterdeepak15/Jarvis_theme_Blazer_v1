@* ================================================================
   JTabs — JARVIS UI Tab Strip
   Angular parallelogram tabs with active scan underline.

   USAGE:
   <JTabs @bind-ActiveTab="activeTab">
       <JTab Key="system"  Label="System"  Icon="⊞" />
       <JTab Key="skills"  Label="Skills"  Icon="⚡" Badge="12" />
       <JTab Key="logs"    Label="Logs"    Icon="≡" />
   </JTabs>
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

<CascadingValue Value="this">
<div>
    @* ── Tab strip ── *@
    <div style="display:flex;border-bottom:1px solid var(--j-accent-12);
                overflow-x:auto;gap:0;">
        @foreach (var tab in _tabs)
        {
            bool active = tab.Key == ActiveTab;
            <button @onclick="() => SelectTab(tab.Key)"
                    style="@TabStyle(active, tab)"
                    type="button">

                @if (!string.IsNullOrWhiteSpace(tab.Icon))
                {
                    <span style="font-style:normal;font-size:13px;@(active ? "filter:drop-shadow(0 0 4px var(--j-accent));" : "")">
                        @tab.Icon
                    </span>
                }

                <span>@tab.Label</span>

                @if (!string.IsNullOrWhiteSpace(tab.Badge))
                {
                    <span style="font-size:8px;padding:1px 5px;
                                 background:var(--j-accent-12);
                                 color:var(--j-accent-mid);
                                 clip-path:polygon(4px 0,100% 0,calc(100% - 4px) 100%,0 100%);">
                        @tab.Badge
                    </span>
                }

                @* Active underline bar *@
                @if (active)
                {
                    <div style="position:absolute;bottom:-1px;left:0;right:0;height:2px;
                                background:var(--j-accent);
                                box-shadow:0 0 8px var(--j-accent);
                                overflow:hidden;">
                        <div style="position:absolute;inset:0;width:30px;
                                    background:linear-gradient(90deg,transparent,var(--j-text-primary),transparent);
                                    animation:j-scan-h 2s ease-in-out infinite;"></div>
                    </div>
                }

            </button>
        }
    </div>

    @* ── Tab content (child JTab components render here) ── *@
    <div style="padding-top:4px;">
        @ChildContent
    </div>
</div>
</CascadingValue>

@code {
    public record JTabDefinition(string Key, string Label, string? Icon = null, string? Badge = null);

    [Parameter] public string?               ActiveTab        { get; set; }
    [Parameter] public EventCallback<string> ActiveTabChanged { get; set; }
    [Parameter] public JColor                Color            { get; set; } = JColor.Cyan;
    [Parameter] public RenderFragment?       ChildContent     { get; set; }

    private readonly List<JTabDefinition> _tabs = new();

    /// <summary>Called by child JTab components to register themselves.</summary>
    internal void RegisterTab(JTabDefinition tab)
    {
        if (_tabs.Any(t => t.Key == tab.Key)) return;
        _tabs.Add(tab);
        // Auto-select first tab
        if (ActiveTab == null && _tabs.Count == 1)
            ActiveTab = tab.Key;
        // Marshal re-render to avoid calling StateHasChanged during child OnInitialized
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>Called by JTab on real parameter changes (label/badge updates).</summary>
    internal void UpdateTab(JTabDefinition tab)
    {
        var idx = _tabs.FindIndex(t => t.Key == tab.Key);
        if (idx < 0) return;
        var existing = _tabs[idx];
        // Only re-render if something actually changed
        if (existing.Label == tab.Label && existing.Icon == tab.Icon && existing.Badge == tab.Badge) return;
        _tabs[idx] = tab;
        StateHasChanged();
    }

    private async Task SelectTab(string key)
    {
        ActiveTab = key;
        await ActiveTabChanged.InvokeAsync(key);
    }

    private string TabStyle(bool active, JTabDefinition tab) =>
        "position:relative;display:flex;align-items:center;gap:6px;" +
        "padding:10px 18px;" +
        "background:transparent;border:none;cursor:pointer;" +
        "font-family:'Courier New',monospace;font-size:10px;font-weight:600;" +
        "letter-spacing:0.12em;text-transform:uppercase;" +
        $"color:{(active ? "var(--j-accent)" : "var(--j-text-muted)")};" +
        "transition:color 0.15s;" +
        "white-space:nowrap;" +
        (active ? "text-shadow:0 0 8px var(--j-accent-50);" : "");
}
