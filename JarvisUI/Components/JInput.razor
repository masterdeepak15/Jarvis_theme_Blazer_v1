@* ================================================================
   JInput — JARVIS UI Text Input
   Angular clip-path input with corner bracket accents and
   animated focus glow. Zero JS — pure CSS + Blazor binding.

   USAGE:
   <JInput @bind-Value="command" Placeholder="Speak or type a command..." />
   <JInput @bind-Value="search" Label="Search skills" Color="JColor.Amber" />
   <JInput @bind-Value="pass" Type="password" Label="Access code" />
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

<div style="@_wrapStyle">

    @* Label *@
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label style="display:block;font-size:9px;color:var(--j-accent-12);
                      letter-spacing:0.12em;text-transform:uppercase;margin-bottom:4px;">
            @Label
        </label>
    }

    @* Corner brackets *@
    <div style="position:relative;">
        <div style="position:absolute;top:0;left:0;width:8px;height:8px;
                    border-top:1.5px solid var(--j-accent);border-left:1.5px solid var(--j-accent);
                    filter:drop-shadow(0 0 3px @_accentHex);z-index:1;pointer-events:none;"></div>
        <div style="position:absolute;bottom:0;right:0;width:8px;height:8px;
                    border-bottom:1.5px solid var(--j-accent);border-right:1.5px solid var(--j-accent);
                    filter:drop-shadow(0 0 3px @_accentHex);z-index:1;pointer-events:none;"></div>

        <input type="@Type"
               value="@Value"
               placeholder="@Placeholder"
               disabled="@Disabled"
               maxlength="@MaxLength"
               @oninput="OnInput"
               @onchange="OnChange"
               style="@_inputStyle" />
    </div>

    @* Helper text *@
    @if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <div style="font-size:9px;color:var(--j-text-muted);margin-top:3px;letter-spacing:0.06em;">@HelperText</div>
    }

</div>

@code {
    [Parameter] public string?       Value       { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string        Placeholder { get; set; } = "";
    [Parameter] public string?       Label       { get; set; }
    [Parameter] public string?       HelperText  { get; set; }
    [Parameter] public string        Type        { get; set; } = "text";
    [Parameter] public JColor        Color       { get; set; } = JColor.Cyan;
    [Parameter] public JState        State       { get; set; } = JState.Active;
    [Parameter] public bool          Disabled    { get; set; } = false;
    [Parameter] public int           MaxLength   { get; set; } = 524288;

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task OnChange(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }

    private string _accentHex => State switch
    {
        JState.Warning => "var(--j-warn)",
        JState.Error   => "var(--j-err)",
        JState.Success => "var(--j-ok)",
        _              => Color switch
        {
            JColor.Amber => "var(--j-warn)",
            JColor.Red   => "var(--j-err)",
            JColor.Green => "var(--j-ok)",
            _            => "var(--j-accent)",
        },
    };

    private string _accentDim => $"var(--j-accent)88";

    private string _wrapStyle => "position:relative;width:100%;";

    private string _inputStyle =>
        $"width:100%;padding:10px 14px;" +
        $"background:var(--j-bg-card);" +
        $"border:1px solid var(--j-accent)33;" +
        $"border-radius:0;" +
        $"color:var(--j-text-primary);" +
        $"font-size:12px;" +
        $"font-family:'Courier New',monospace;" +
        $"letter-spacing:0.06em;" +
        $"outline:none;" +
        $"box-sizing:border-box;" +
        $"clip-path:polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);" +
        $"transition:border-color 0.2s,box-shadow 0.2s;" +
        (Disabled ? "opacity:0.4;cursor:not-allowed;" : "");
}
