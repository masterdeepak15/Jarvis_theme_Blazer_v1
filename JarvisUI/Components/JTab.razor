@* Individual tab registration — used inside JTabs *@
@using JarvisUI.Tokens
@namespace JarvisUI.Components

@* No visible markup — registers with parent JTabs and renders content when active *@
@if (_parent?.ActiveTab == Key)
{
    @ChildContent
}

@code {
    [Parameter] public string          Key          { get; set; } = "";
    [Parameter] public string          Label        { get; set; } = "";
    [Parameter] public string?         Icon         { get; set; }
    [Parameter] public string?         Badge        { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [CascadingParameter] private JTabs? _parent { get; set; }

    // Track previous values to detect real changes and avoid re-render loops
    private string  _prevKey   = "";
    private string  _prevLabel = "";
    private string? _prevIcon;
    private string? _prevBadge;

    protected override void OnInitialized()
    {
        _prevKey = Key; _prevLabel = Label; _prevIcon = Icon; _prevBadge = Badge;
        _parent?.RegisterTab(new JTabs.JTabDefinition(Key, Label, Icon, Badge));
    }

    protected override void OnParametersSet()
    {
        // Only notify parent if something actually changed — prevents infinite render loop
        if (Key   == _prevKey   && Label == _prevLabel &&
            Icon  == _prevIcon  && Badge == _prevBadge) return;

        _prevKey = Key; _prevLabel = Label; _prevIcon = Icon; _prevBadge = Badge;
        _parent?.UpdateTab(new JTabs.JTabDefinition(Key, Label, Icon, Badge));
    }
}
