@* ================================================================
   JToggle — JARVIS UI Toggle Switch
   Angular track + diamond sliding thumb. No JS.

   USAGE:
   <JToggle @bind-Value="isListening" Label="Listening" />
   <JToggle @bind-Value="hudOverlay"  Label="HUD Overlay" Color="JColor.Amber" />
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

<div style="display:flex;align-items:center;gap:10px;cursor:pointer;" @onclick="Toggle">

    @* Track *@
    <div style="@_trackStyle">
        @* Thumb — diamond shape *@
        <div style="@_thumbStyle"></div>
        @* Active fill *@
        @if (Value)
        {
            <div style="@_fillStyle"></div>
        }
    </div>

    @* Label *@
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <span style="font-size:10px;color:@(Value ? _accentHex : "var(--j-text-muted)");
                     letter-spacing:0.10em;text-transform:uppercase;
                     transition:color 0.2s;user-select:none;">
            @Label
        </span>
    }

</div>

@code {
    [Parameter] public bool          Value       { get; set; } = false;
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public string?        Label       { get; set; }
    [Parameter] public JColor         Color       { get; set; } = JColor.Cyan;
    [Parameter] public bool           Disabled    { get; set; } = false;

    private async Task Toggle()
    {
        if (Disabled) return;
        Value = !Value;
        await ValueChanged.InvokeAsync(Value);
    }

    private string _accentHex => "var(--j-accent)";

    private string _trackStyle =>
        $"position:relative;width:40px;height:22px;" +
        $"background:{(Value == true ? _accentHex + "18" : "var(--j-accent-08)")};" +
        $"border:1px solid {(Value == true ? _accentHex : "var(--j-accent-18)")};" +
        $"clip-path:polygon(4px 0,100% 0,calc(100% - 4px) 100%,0 100%);" +
        $"transition:background 0.2s,border-color 0.2s;" +
        $"cursor:{(Disabled ? "not-allowed" : "pointer")};" +
        (Value == true ? $"box-shadow:0 0 8px var(--j-accent)44;" : "");

    private string _thumbStyle =>
        $"position:absolute;top:50%;width:10px;height:10px;" +
        $"background:{(Value == true ? _accentHex : "var(--j-text-dim)")};" +
        $"clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);" +
        $"transition:left 0.2s,background 0.2s;" +
        $"left:{(Value == true ? "24px" : "5px")};" +
        $"transform:translateY(-50%);" +
        (Value == true ? $"box-shadow:0 0 8px var(--j-accent);" : "");

    private string _fillStyle =>
        $"position:absolute;inset:0;" +
        $"background:linear-gradient(90deg,var(--j-accent)08,var(--j-accent)22);" +
        "pointer-events:none;";
}
