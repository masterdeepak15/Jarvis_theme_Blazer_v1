@* ================================================================
   JOrb — JARVIS UI Identity Orb
   The main centerpiece HUD element — exactly like LINKS Mark II.
   Concentric animated rings, inner label, state-driven behavior,
   click to toggle listening on/off.

   USAGE:
   <JOrb SystemName="JARVIS" State="JState.Active" Size="160px"
         Listening="true" OnClick="ToggleListen" />
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

<div style="@_wrapStyle" @onclick="OnClick" title="@(Listening ? "Click to stop" : "Click to activate")">

    @* ── Outer dashed orbit (slowest) ── *@
    <div style="@_ringStyle(0, "dashed", "0.08", "10s", false)"></div>

    @* ── Tick marks on outer ring ── *@
    @for (int i = 0; i < 12; i++)
    {
        double angle = i * 30.0;
        <div style="@_tickStyle(angle)"></div>
    }

    @* ── Ring 1 — solid, medium speed ── *@
    <div style="@_ringStyle(8, "solid", "0.35", _r1Speed, false)"></div>

    @* ── Ring 2 — top+bottom color, fast ── *@
    <div style="@_ringStyleSplit(16, _r2Speed, false)"></div>

    @* ── Ring 3 — counter-rotating ── *@
    <div style="@_ringStyleSplit(24, _r3Speed, true)"></div>

    @* ── Inner filled circle ── *@
    <div style="@_innerStyle">

        @* Inner radial glow *@
        <div style="position:absolute;inset:0;border-radius:50%;
                    background:radial-gradient(circle at 40% 35%, @_accentGlow 0%, transparent 65%);
                    pointer-events:none;"></div>

        @* System name *@
        <div style="position:relative;z-index:1;text-align:center;">
            <div style="font-size:@_nameFontSize;font-weight:600;
                        color:#e0f7ff;letter-spacing:0.16em;text-transform:uppercase;
                        text-shadow:0 0 16px @_accentHex;
                        animation:j-glitch 8s ease-in-out infinite;">
                @SystemName
            </div>
            <div style="font-size:@_stateFontSize;color:@_accentHex;
                        letter-spacing:0.14em;text-transform:uppercase;
                        margin-top:2px;
                        animation:j-pulse var(--j-dur-pulse) ease-in-out infinite;">
                @_stateLabel
            </div>
        </div>

    </div>

    @* ── Orange / active indicator button ── *@
    <div style="@_indicatorStyle" @onclick:stopPropagation="true" @onclick="OnClick">
        <div style="width:10px;height:10px;border-radius:50%;
                    background:@(Listening ? _accentHex : "#334155");
                    box-shadow:@(Listening ? $"0 0 12px {_accentHex},0 0 24px {_accentGlow}" : "none");
                    transition:all 0.3s;
                    animation:@(Listening ? "j-pulse 1.2s ease-in-out infinite" : "none");">
        </div>
    </div>

</div>

@code {
    [Parameter] public string        SystemName { get; set; } = "JARVIS";
    [Parameter] public string        Size       { get; set; } = "160px";
    [Parameter] public JColor        Color      { get; set; } = JColor.Cyan;
    [Parameter] public JState        State      { get; set; } = JState.Active;
    [Parameter] public bool          Listening  { get; set; } = false;
    [Parameter] public EventCallback OnClick    { get; set; }

    // ── Color tokens ──────────────────────────────────────────────
    private string _accentHex => Color switch
    {
        JColor.Amber => "#f97316",
        JColor.Red   => "#ef4444",
        JColor.Green => "#22c55e",
        _            => "#00e5ff",
    };
    private string _accentGlow => Color switch
    {
        JColor.Amber => "rgba(249,115,22,0.30)",
        JColor.Red   => "rgba(239,68,68,0.30)",
        JColor.Green => "rgba(34,197,94,0.25)",
        _            => "rgba(0,229,255,0.25)",
    };
    private string _accentDim => Color switch
    {
        JColor.Amber => "rgba(249,115,22,0.12)",
        JColor.Red   => "rgba(239,68,68,0.12)",
        _            => "rgba(0,229,255,0.10)",
    };

    // ── Ring speeds driven by state ───────────────────────────────
    private string _r1Speed => State switch
    {
        JState.Processing => "2s",
        JState.Idle       => "8s",
        _                 => "4s",
    };
    private string _r2Speed => State switch
    {
        JState.Processing => "1.2s",
        JState.Idle       => "6s",
        _                 => "3s",
    };
    private string _r3Speed => State switch
    {
        JState.Processing => "1.8s",
        JState.Idle       => "9s",
        _                 => "5s",
    };

    // ── State label ───────────────────────────────────────────────
    private string _stateLabel => State switch
    {
        JState.Idle       => "Idle",
        JState.Processing => "Processing",
        JState.Warning    => "Warning",
        JState.Error      => "Error",
        _                 => Listening ? "Listening" : "Online",
    };

    // ── Font sizes scale with orb size ────────────────────────────
    private string _nameFontSize => "14px";
    private string _stateFontSize => "9px";

    // ── Styles ────────────────────────────────────────────────────
    private string _wrapStyle =>
        $"position:relative;width:{Size};height:{Size};" +
        "display:flex;align-items:center;justify-content:center;" +
        "cursor:pointer;flex-shrink:0;";

    private string _ringStyle(int insetPx, string style, string opacity, string speed, bool reverse) =>
        $"position:absolute;border-radius:50%;" +
        $"inset:{insetPx}px;" +
        $"border:1px {style} {_accentHex};" +
        $"opacity:{opacity};" +
        $"animation:j-spin{(reverse ? "-rev" : "")} {speed} linear infinite;";

    private string _ringStyleSplit(int insetPx, string speed, bool reverse) =>
        $"position:absolute;border-radius:50%;" +
        $"inset:{insetPx}px;" +
        $"border:1.5px solid transparent;" +
        $"border-top-color:{_accentHex};" +
        $"border-bottom-color:{_accentHex}66;" +
        $"box-shadow:0 0 6px {_accentGlow};" +
        $"animation:j-spin{(reverse ? "-rev" : "")} {speed} linear infinite;";

    private string _innerStyle =>
        "position:absolute;inset:32px;border-radius:50%;" +
        $"background:radial-gradient(circle at 38% 36%, {_accentDim}, #020d18 70%);" +
        $"border:1px solid {_accentHex}44;" +
        "display:flex;align-items:center;justify-content:center;" +
        $"box-shadow:inset 0 0 20px {_accentGlow},0 0 16px {_accentGlow};" +
        "overflow:hidden;";

    private string _tickStyle(double angle)
    {
        double rad = angle * Math.PI / 180;
        double r = 48; // % of half-size
        double x = 50 + r * Math.Sin(rad);
        double y = 50 - r * Math.Cos(rad);
        return $"position:absolute;width:2px;height:4px;" +
               $"background:{_accentHex};opacity:0.35;" +
               $"left:{x:F1}%;top:{y:F1}%;" +
               $"transform:translate(-50%,-50%) rotate({angle}deg);";
    }

    private string _indicatorStyle =>
        "position:absolute;bottom:18%;left:50%;transform:translateX(-50%);" +
        "width:24px;height:24px;border-radius:50%;" +
        "background:#020d18;" +
        $"border:1px solid {_accentHex}44;" +
        "display:flex;align-items:center;justify-content:center;" +
        "cursor:pointer;z-index:2;";
}
