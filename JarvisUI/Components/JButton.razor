@* ================================================================
   JButton — JARVIS UI Button Component
   8 distinct angular HUD button shapes. Pure CSS animations.
   Zero JavaScript.

   USAGE:
   <JButton Shape="JButtonShape.LeftNotch" OnClick="HandleClick">Execute</JButton>
   <JButton Shape="JButtonShape.Parallelogram" Variant="JVariant.Ghost">Cancel</JButton>
   <JButton Shape="JButtonShape.IconSquare" Icon="⚙" />
   <JButton Shape="JButtonShape.LeftNotch" Variant="JVariant.Danger">Shutdown</JButton>
================================================================ *@

@using JarvisUI.Tokens
@namespace JarvisUI.Components

<button class="@_rootClass"
        style="@_rootStyle"
        disabled="@Disabled"
        type="@Type"
        @onclick="OnClick"
        @onclick:stopPropagation="StopPropagation">

    @* ── Shape-specific background / SVG layer ── *@
    @switch (Shape)
    {
        case JButtonShape.LeftNotch:
        case JButtonShape.RightNotch:
        case JButtonShape.BothNotch:
            <svg class="j-btn-bg-svg" viewBox="0 0 @_svgW 40"
                 preserveAspectRatio="none"
                 style="position:absolute;inset:0;width:100%;height:100%;">
                <polygon class="j-btn-fill"   points="@_fillPts" style="@_fillStyle" />
                <polygon class="j-btn-border" points="@_fillPts" style="@_borderStyle" />
                @if (Shape == JButtonShape.LeftNotch || Shape == JButtonShape.BothNotch)
                {
                    <polygon points="0,0 10,0 0,10" style="fill:@_accentHex;" />
                }
                @if (Shape == JButtonShape.RightNotch || Shape == JButtonShape.BothNotch)
                {
                    <polygon points="@(_svgW),0 @(_svgW - 10),0 @(_svgW),10" style="fill:@_accentHex;opacity:0.5;" />
                }
            </svg>
            if (ShowShine) { <div class="j-btn-shine"></div> }
            break;

        case JButtonShape.BracketFrame:
            <div class="j-btn-bg-fill" style="position:absolute;inset:0;@_bracketBgStyle">
                <div class="j-btn-top-line"></div>
                <div class="j-btn-bot-line"></div>
            </div>
            break;

        case JButtonShape.Parallelogram:
            <div class="j-btn-bg-fill" style="@_paraFillStyle"></div>
            <div class="j-btn-rail"    style="@_paraRailStyle"></div>
            if (ShowShine) { <div class="j-btn-shine"></div> }
            break;

        case JButtonShape.GhostSkew:
            <div class="j-btn-bg-fill" style="position:absolute;inset:0;background:transparent;border:1px dashed @_accentHex;opacity:0.4;"></div>
            break;

        case JButtonShape.Hexagonal:
            <div class="j-btn-bg-fill" style="@_hexFillStyle"></div>
            break;

        case JButtonShape.IconSquare:
            <div class="j-btn-bg-fill" style="@_iconSqFillStyle"></div>
            break;

        case JButtonShape.ScanFull:
            <div class="j-btn-bg-fill" style="position:absolute;inset:0;background:@_accentHex;"></div>
            <div class="j-btn-shine" style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.30),transparent);"></div>
            break;
    }

    @* ── Label / Icon ── *@
    <span class="j-btn-label" style="@_labelStyle">
        @if (!string.IsNullOrWhiteSpace(Icon) && IconPosition == JIconPosition.Left)
        {
            <span style="font-style:normal;margin-right:6px;">@Icon</span>
        }
        @if (!string.IsNullOrWhiteSpace(Icon) && string.IsNullOrWhiteSpace(Label) && ChildContent == null)
        {
            @Icon
        }
        else
        {
            @ChildContent
            @Label
        }
        @if (!string.IsNullOrWhiteSpace(Icon) && IconPosition == JIconPosition.Right)
        {
            <span style="font-style:normal;margin-left:6px;">@Icon</span>
        }
    </span>

</button>

@code {
    public enum JIconPosition { Left, Right }

    // ── Parameters ────────────────────────────────────────────────
    [Parameter] public JButtonShape    Shape           { get; set; } = JButtonShape.LeftNotch;
    [Parameter] public JVariant        Variant         { get; set; } = JVariant.Outline;
    [Parameter] public JColor          Color           { get; set; } = JColor.Cyan;
    [Parameter] public JSize           Size            { get; set; } = JSize.Md;
    [Parameter] public JAnimSpeed      AnimSpeed       { get; set; } = JAnimSpeed.Normal;
    [Parameter] public string?         Label           { get; set; }
    [Parameter] public string?         Icon            { get; set; }
    [Parameter] public JIconPosition   IconPosition    { get; set; } = JIconPosition.Left;
    [Parameter] public bool            ShowShine       { get; set; } = true;
    [Parameter] public bool            Disabled        { get; set; } = false;
    [Parameter] public bool            StopPropagation { get; set; } = false;
    [Parameter] public string          Type            { get; set; } = "button";
    [Parameter] public EventCallback   OnClick         { get; set; }
    [Parameter] public RenderFragment? ChildContent    { get; set; }

    // ── Color lookup ──────────────────────────────────────────────
    private string _accentHex => Color switch
    {
        JColor.Cyan  => "#00e5ff",
        JColor.Blue  => "#0891b2",
        JColor.Amber => "#f97316",
        JColor.Red   => "#ef4444",
        JColor.Green => "#22c55e",
        JColor.Ghost => "rgba(255,255,255,0.3)",
        JColor.White => "#ffffff",
        _            => "#00e5ff",
    };

    private string _accentDim => Color switch
    {
        JColor.Cyan  => "rgba(0,229,255,0.12)",
        JColor.Amber => "rgba(249,115,22,0.12)",
        JColor.Red   => "rgba(239,68,68,0.12)",
        JColor.Green => "rgba(34,197,94,0.12)",
        _            => "rgba(0,229,255,0.12)",
    };

    private string _accentGlow => Color switch
    {
        JColor.Cyan  => "rgba(0,229,255,0.35)",
        JColor.Amber => "rgba(249,115,22,0.35)",
        JColor.Red   => "rgba(239,68,68,0.35)",
        JColor.Green => "rgba(34,197,94,0.30)",
        _            => "rgba(0,229,255,0.35)",
    };

    // ── SVG polygon points ────────────────────────────────────────
    private int _svgW => Size switch
    {
        JSize.Xs => 100,
        JSize.Sm => 120,
        JSize.Md => 150,
        JSize.Lg => 170,
        JSize.Xl => 200,
        _        => 150,
    };

    private string _fillPts => Shape switch
    {
        JButtonShape.LeftNotch  => $"10,0 {_svgW},0 {_svgW},40 0,40 0,10",
        JButtonShape.RightNotch => $"0,0 {_svgW - 10},0 {_svgW},10 {_svgW},40 0,40",
        JButtonShape.BothNotch  => $"10,0 {_svgW - 10},0 {_svgW},10 {_svgW},40 {_svgW - 10},40 10,40 0,30 0,10",
        _                       => $"10,0 {_svgW},0 {_svgW},40 0,40 0,10",
    };

    private string _fillStyle => Variant switch
    {
        JVariant.Solid  => $"fill:{_accentHex};",
        JVariant.Danger => $"fill:{_accentDim};",
        _               => $"fill:{_accentDim};",
    };

    private string _borderStyle => Variant switch
    {
        JVariant.Solid  => $"fill:none;stroke:{_accentHex};stroke-width:0;",
        JVariant.Danger => $"fill:none;stroke:{_accentHex};stroke-width:1;",
        _               => $"fill:none;stroke:{_accentHex};stroke-width:1;",
    };

    // ── Root class ────────────────────────────────────────────────
    private string _rootClass => JarvisClasses.Combine(
        "j-btn",
        Shape switch
        {
            JButtonShape.Parallelogram => "j-btn-parallelogram",
            JButtonShape.GhostSkew     => "j-btn-ghost-skew",
            JButtonShape.BracketFrame  => "j-btn-bracket",
            JButtonShape.Hexagonal     => "j-btn-hex",
            JButtonShape.IconSquare    => "j-btn-icon-sq",
            JButtonShape.ScanFull      => "j-btn-scan-full",
            _                          => "",
        },
        JarvisClasses.Color(Color),
        JarvisClasses.Size(Size),
        JarvisClasses.AnimSpeed(AnimSpeed),
        Disabled ? "j-btn-disabled" : null,
        Variant == JVariant.Danger ? "j-state-error" : null
    );

    // ── Root inline style ─────────────────────────────────────────
    private string _rootStyle => Shape switch
    {
        JButtonShape.IconSquare => $"width:var(--j-h,40px);height:var(--j-h,40px);overflow:hidden;",
        JButtonShape.Hexagonal  => $"overflow:hidden;",
        JButtonShape.ScanFull   => $"overflow:hidden;width:100%;",
        _                       => "overflow:hidden;",
    } + (Disabled ? "opacity:0.4;cursor:not-allowed;" : "");

    // ── Label style ───────────────────────────────────────────────
    private string _labelStyle
    {
        get
        {
            string color = Variant switch
            {
                JVariant.Solid   => "color:#020d18;",
                JVariant.Danger  => $"color:{_accentHex};",
                JVariant.Ghost   => $"color:{_accentHex};opacity:0.55;",
                JVariant.Scan    => "color:#020d18;",
                _                => $"color:{_accentHex};",
            };

            string glow = Variant == JVariant.Solid || Variant == JVariant.Scan
                ? ""
                : $"text-shadow:0 0 8px {_accentGlow};";

            return color + glow;
        }
    }

    // ── Shape-specific styles ─────────────────────────────────────
    private string _paraFillStyle =>
        $"position:absolute;inset:0;background:{_accentDim};border:1px solid {_accentHex};opacity:0.7;";

    private string _paraRailStyle =>
        $"position:absolute;top:0;bottom:0;left:0;width:3px;background:{_accentHex};box-shadow:0 0 8px {_accentHex};";

    private string _hexFillStyle =>
        $"position:absolute;inset:0;background:{_accentDim};" +
        $"clip-path:polygon(12% 0%,88% 0%,100% 50%,88% 100%,12% 100%,0% 50%);" +
        $"border:1px solid {_accentHex};animation:j-pulse var(--j-dur-pulse) ease-in-out infinite;";

    private string _iconSqFillStyle =>
        $"position:absolute;inset:0;background:{_accentDim};" +
        $"border:1px solid {_accentHex};opacity:0.8;";

    private string _bracketBgStyle =>
        $"--j-accent:{_accentHex};";
}
